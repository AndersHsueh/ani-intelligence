{
  "name": "ani-cli",
  "version": "0.5.6",
  "description": "Ani - AI-powered office assistant CLI with Function Calling support",
  "type": "module",
  "bin": {
    "ani": "./dist/index.js",
    "ani-daemon": "./dist/daemon/cli.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "dev:watch": "tsx watch src/index.tsx",
    "build": "tsc && cp -r src/i18n/locales dist/i18n/locales",
    "postbuild": "chmod +x dist/index.js dist/daemon/cli.js",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "script:test-model": "tsx src/scripts/test-model.ts",
    "script:test-tools": "tsx src/scripts/test-tools.ts",
    "script:test-function-calling": "tsx src/scripts/test-function-calling.ts",
    "test:xai": "tsx test/xai-connection.ts"
  },
  "keywords": [
    "cli",
    "ai",
    "assistant",
    "office",
    "productivity",
    "function-calling",
    "tools",
    "llm"
  ],
  "author": "Anders",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AndersHsueh/ani-intelligence.git"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@google/genai": "^1.47.0",
    "@iarna/toml": "^2.2.5",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@qwen-code/web-templates": "file:../../powerful-app/qwen-code/packages/web-templates",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "ansi-escapes": "^7.0.0",
    "axios": "^1.6.5",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "command-exists": "^1.2.9",
    "commander": "^14.0.3",
    "comment-json": "^4.6.2",
    "diff": "^7.0.0",
    "dotenv": "^17.3.1",
    "figlet": "^1.7.0",
    "fzf": "^0.5.2",
    "glob": "^13.0.1",
    "gradient-string": "^2.0.2",
    "highlight.js": "^11.11.1",
    "ink": "^6.2.3",
    "ink-gradient": "^3.0.0",
    "ink-link": "^4.1.0",
    "ink-spinner": "^5.0.0",
    "jsonc-parser": "^3.3.1",
    "lowlight": "^3.3.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "open": "^10.1.2",
    "p-limit": "^7.3.0",
    "prompts": "^2.4.2",
    "react": "^19.1.0",
    "read-package-up": "^12.0.0",
    "shell-quote": "^1.8.3",
    "simple-git": "^3.30.0",
    "string-width": "^7.1.0",
    "strip-ansi": "^7.1.0",
    "strip-json-comments": "^5.0.3",
    "undici": "^7.24.5",
    "update-notifier": "^7.3.1",
    "wrap-ansi": "^9.0.0",
    "yargs": "^18.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/command-exists": "^1.2.3",
    "@types/diff": "^7.0.0",
    "@types/figlet": "^1.5.8",
    "@types/gradient-string": "^1.1.6",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^20.11.5",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.1.0",
    "@types/shell-quote": "^1.7.5",
    "@types/yargs": "^17.0.35",
    "rimraf": "^5.0.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "imports": {
    "@qwen-code/qwen-code-core": "./dist/shim/qwen-code-core.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pkg": {
    "targets": [
      "node20-win-x64",
      "node20-macos-x64",
      "node20-macos-arm64",
      "node20-linux-x64"
    ],
    "outputPath": "dist",
    "assets": [
      "node_modules/figlet/fonts/**/*"
    ]
  }
}
